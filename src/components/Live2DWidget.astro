		const setPosition = (x, bottom = bottomOffset, shouldStore = true) => {
			const position = clampPosition(x, bottom);
			widget.style.left = `${position.x}px`;
			widget.style.top = "auto";
			widget.style.right = "auto";
			widget.style.bottom = `${position.bottom}px`;
			if (shouldStore) {
				localStorage.setItem(positionStorageKey, JSON.stringify(position));
			}
		};

		const restorePosition = () => {
			try {
				const stored = JSON.parse(localStorage.getItem(positionStorageKey) || "null");
				if (
					stored &&
					typeof stored.x === "number"
				) {
					const storedBottom =
						typeof stored.bottom === "number" ? stored.bottom : bottomOffset;
					setPosition(stored.x, storedBottom, false);
					return;
				}
			} catch {
				localStorage.removeItem(positionStorageKey);
			}
			const position = getDefaultPosition();
			setPosition(position.x, position.bottom, false);
		};

		const setHidden = (hidden) => {
			widget.classList.toggle("live2d-hidden", hidden);
			toggle.textContent = hidden ? "L2D" : "×";
			toggle.setAttribute(
				"aria-label",
				hidden ? "Show Live2D model" : "Hide Live2D model",
			);
			localStorage.setItem("live2d-hidden", hidden ? "true" : "false");
			restorePosition();
		};

		const setStatus = (message) => {
			status.textContent = message;
		};

		const getCurrentLanguage = () =>
			document.documentElement.dataset.language === "en" ? "en" : "zh";

		const estimateSpeechDuration = (text) => {
			const normalized = String(text ?? "").trim();
			const compact = normalized.replace(/\s+/g, "");
			const cjkCount =
				compact.match(/[\u3400-\u9fff\u3040-\u30ff\uac00-\ud7af]/g)?.length ?? 0;
			const latinWordCount =
				normalized.match(/[A-Za-z0-9]+(?:[-'][A-Za-z0-9]+)*/g)?.length ?? 0;
			const punctuationCount =
				compact.match(/[，。！？、；：,.!?;:~～]/g)?.length ?? 0;
			const otherCount = Math.max(0, compact.length - cjkCount - punctuationCount);
			const speechUnits =
				cjkCount * 1.35 +
				latinWordCount * 2.1 +
				otherCount * 0.45 +
				punctuationCount * 0.55;
			return Math.round(Math.min(6200, Math.max(1300, 700 + speechUnits * 150)));
		};

		const activateSpeechProfile = (messageIndex, text) => {
			const baseProfile =
				speechProfiles[messageIndex % speechProfiles.length] ?? speechProfiles[0];
			const duration = estimateSpeechDuration(text);
			const profile = { ...baseProfile, duration };
			const now = performance.now();
			activeSpeechProfile = profile;
			speechProfileStartedAt = now;
			speechProfileUntil = now + profile.duration;
			gestureSeed = Math.random() * Math.PI * 2;
			expressionUntil = Math.max(expressionUntil, speechProfileUntil);
			blushUntil = Math.max(blushUntil, now + profile.cheek * profile.duration);
			return profile;
		};

		const showBubble = () => {
			const messageIndex = Math.floor(Math.random() * live2dMessages.length);
			const message = live2dMessages[messageIndex];
			if (!message) return;

			const text = message[getCurrentLanguage()] || message.zh;
			bubble.textContent = text;
			const profile = activateSpeechProfile(messageIndex, text);
			bubble.classList.add("live2d-bubble-active");
			window.requestAnimationFrame(() => {
				const bubbleRect = bubble.getBoundingClientRect();
				const widgetRect = widget.getBoundingClientRect();
				let offsetX = 0;

				if (bubbleRect.left < 8) {
					offsetX = 8 - bubbleRect.left;
				} else if (bubbleRect.right > window.innerWidth - 8) {
					offsetX = window.innerWidth - 8 - bubbleRect.right;
				}

				bubble.style.left = `${4 + offsetX}px`;
				if (bubbleRect.top < 8) {
					bubble.style.bottom = "auto";
					bubble.style.top = `${Math.max(4, widgetRect.height * 0.08)}px`;
				} else {
					bubble.style.top = "auto";
					bubble.style.bottom = "calc(100% + 0.35rem)";
				}
			});
			window.clearTimeout(bubbleTimer);
			bubbleTimer = window.setTimeout(() => {
				bubble.classList.remove("live2d-bubble-active");
			}, Math.max(3000, profile.duration + 800));
			return profile;
		};

		const getSelectedModel = () => {
			const storedModelId = localStorage.getItem(modelStorageKey);
			return modelsById.get(storedModelId) ?? modelsById.get(defaultModelId) ?? modelData[0];
		};

		const syncModelSelect = () => {
			const selectedModel = getSelectedModel();
			select.value = selectedModel.id;
		};

		const loadScript = (src) =>
			new Promise((resolve, reject) => {
				const existing = document.querySelector(`script[src="${src}"]`);
				if (existing) {
					existing.addEventListener("load", resolve, { once: true });
					existing.addEventListener("error", reject, { once: true });
					if (existing.dataset.loaded === "true") resolve();
					return;
				}

				const script = document.createElement("script");
				script.src = src;
				script.async = true;
				script.onload = () => {
					script.dataset.loaded = "true";
					resolve();
				};
				script.onerror = reject;
				document.head.appendChild(script);
			});

			const disposeModel = () => {
				if (live2dModel) {
					live2dApp?.stage.removeChild(live2dModel);
					live2dModel.destroy();
					live2dModel = null;
				}
				handPartLock = null;
				neutralHandPartLock = null;
				poseParameterLock = null;
				neutralPoseParameterLock = null;
				if (resizeModel) {
					window.removeEventListener("resize", resizeModel);
					resizeModel = null;
				}
				live2dLoaded = false;
			};

		const prepareRuntime = async () => {
			if (live2dRuntimeReady) return true;
			try {
				await loadScript("https://cdn.jsdelivr.net/npm/pixi.js@6.5.10/dist/browser/pixi.min.js");
				window.PIXI = PIXI;
				await loadScript("https://cubism.live2d.com/sdk-web/cubismcore/live2dcubismcore.min.js");
				await loadScript("https://cdn.jsdelivr.net/npm/pixi-live2d-display@0.4.0/dist/cubism4.min.js");
				live2dRuntimeReady = true;
				return true;
			} catch (error) {
				widget.classList.add("live2d-error");
				setStatus("Live2D CDN failed");
				console.error("Live2D SDK failed to load:", error);
				return false;
			}
		};

		const getApp = () => {
			if (!live2dApp) {
				live2dApp = new PIXI.Application({
					view: canvas,
					autoStart: true,
					backgroundAlpha: 0,
					antialias: true,
					autoDensity: true,
					resolution: Math.min(window.devicePixelRatio || 1, 2),
					resizeTo: widget,
				});
				const syncExpression = () => {
					if (!live2dModel) return;

					const now = performance.now();
					const speechProfile =
						activeSpeechProfile && now < speechProfileUntil
							? activeSpeechProfile
							: null;
					const speechEase = getSpeechEase(now);
					syncPoseParameterLock(live2dModel);
					syncLiveliness(live2dModel, now, speechProfile, speechEase);
					syncHandPartLock(live2dModel);

					const expressionActive = now < expressionUntil;
					const blushActive = now < blushUntil;
					syncSpeechExpression(
						live2dModel,
						speechProfile,
						speechEase,
						expressionActive,
						blushActive,
					);
				};
				live2dApp.ticker.add(
					syncExpression,
					undefined,
					(PIXI.UPDATE_PRIORITY?.LOW ?? 0) - 1,
				);
			}
			return live2dApp;
		};

		const playTapMotion = (event) => {
			setStatus("Live2D touched");
			showBubble();
			widget.classList.remove("live2d-tapped");
			void widget.offsetWidth;
			widget.classList.add("live2d-tapped");
			openModelMouth();
			if (isUpperModelTap(event)) {
				blushUntil = performance.now() + 2800;
			}
			window.setTimeout(() => {
				if (widget.classList.contains("live2d-ready")) {
					setStatus("Live2D ready");
				}
			}, 900);
		};

		const resolveCubismId = (id) => {
			try {
				const framework =
					window.Live2DCubismFramework?.CubismFramework ??
					window.live2dcubismframework?.CubismFramework;
				return framework?.getIdManager?.().getId?.(id) ?? id;
			} catch {
				return id;
			}
		};

		const getCoreModel = (model) => model.internalModel?.coreModel;

		const setModelParameter = (model, parameterIds, value) => {
			const coreModel = getCoreModel(model);
			for (const id of parameterIds) {
				const cubismId = resolveCubismId(id);
				try {
					coreModel.setParameterValueById(cubismId, value);
					continue;
				} catch {
					// Fall back to the low-level Cubism Core arrays below.
				}

				try {
					const rawModel = coreModel?._model ?? coreModel?.model;
					const ids = rawModel?.parameters?.ids ?? coreModel?._parameterIds;
					const values =
						rawModel?.parameters?.values ?? coreModel?._parameterValues;
					const index = findCubismIdIndex(ids, id);
					if (index >= 0 && values) values[index] = value;
				} catch {
					// Some models use a different parameter set.
				}
			}
		};

		const addModelParameter = (model, parameterIds, value, weight = 1) => {
			const coreModel = getCoreModel(model);
			for (const id of parameterIds) {
				try {
					coreModel.addParameterValueById(resolveCubismId(id), value, weight);
				} catch {
					// Additive liveliness is optional for models without this parameter.
				}
			}
		};

		const getCubismIdValue = (id) =>
			String(id?._id ?? id?.id ?? id?._s ?? id?.s ?? id);

		const findCubismIdIndex = (ids, targetId) => {
			if (!ids) return -1;
			return Array.from(ids).findIndex((id) => getCubismIdValue(id) === targetId);
		};

			const getIdleProfile = () =>
				characterIdleProfiles[currentModelId] ??
				characterIdleProfiles[defaultModelId] ??
				{};

			const getWidgetFacingDirection = () => {
				const rect = widget.getBoundingClientRect();
				return rect.left + rect.width / 2 < window.innerWidth / 2 ? 1 : -1;
			};

		const setModelPartOpacity = (model, partId, value) => {
			const coreModel = getCoreModel(model);
			const cubismId = resolveCubismId(partId);
			try {
				coreModel.setPartOpacityById(cubismId, value);
				return;
			} catch {
				// Fall back to direct Cubism Core part opacity arrays.
			}

			try {
				const rawModel = coreModel?._model ?? coreModel?.model;
				const ids = rawModel?.parts?.ids ?? coreModel?._partIds;
				const opacities = rawModel?.parts?.opacities ?? coreModel?._partOpacities;
				const index = findCubismIdIndex(ids, partId);
				if (index >= 0 && opacities) opacities[index] = value;
			} catch {
				// Leave the part untouched if this runtime does not expose it.
			}
		};

			const easeInOut = (value) => {
				const clamped = Math.min(1, Math.max(0, value));
				return clamped * clamped * (3 - clamped * 2);
			};

			const getPoseBlend = (now = performance.now()) => {
				const holdMs = 2100;
				const transitionMs = 1100;
				return easeInOut((now - poseStartedAt - holdMs) / transitionMs);
			};

			const syncHandPartLock = (model) => {
				const poseBlend = getPoseBlend();
				const activeHandPartLock =
					poseBlend < 0.65 && neutralHandPartLock
						? neutralHandPartLock
						: handPartLock ?? neutralHandPartLock;
				if (!activeHandPartLock) return;
				for (const [partId, opacity] of activeHandPartLock) {
					setModelPartOpacity(model, partId, opacity);
				}
			};

			const syncPoseParameterLock = (model) => {
				if (!poseParameterLock && !neutralPoseParameterLock) return;
				const poseBlend = getPoseBlend();
				const parameterIds = new Set([
					...(neutralPoseParameterLock?.keys() ?? []),
					...(poseParameterLock?.keys() ?? []),
				]);
				for (const parameterId of parameterIds) {
					const neutralValue = neutralPoseParameterLock?.get(parameterId) ?? 0;
					const poseValue = poseParameterLock?.get(parameterId) ?? neutralValue;
					setModelParameter(
						model,
						[parameterId],
						neutralValue + (poseValue - neutralValue) * poseBlend,
					);
				}
			};

		const getSpeechEase = (now) => {
			if (!activeSpeechProfile || now >= speechProfileUntil) return 0;
			const elapsed = now - speechProfileStartedAt;
			const remaining = speechProfileUntil - now;
			const fadeIn = Math.min(1, Math.max(0, elapsed / 220));
			const fadeOut = Math.min(1, Math.max(0, remaining / 520));
			return fadeIn * fadeOut;
		};

		const syncSpeechExpression = (
			model,
			profile,
			ease,
			expressionActive,
			blushActive,
		) => {
			const mouthOpen = Math.max(
				expressionActive ? 0.95 : 0,
				profile ? profile.mouthOpen * ease : 0,
			);
			const idleProfile = getIdleProfile();
			const idleExpressionWeight = profile ? Math.max(0, 1 - ease) : 1;
			const eyeSmile = Math.max(
				blushActive ? 0.85 : 0,
				expressionActive ? 0.35 : 0,
				profile ? profile.eyeSmile * ease : 0,
				(idleProfile.eyeSmile ?? 0) * idleExpressionWeight,
			);
			const cheek = Math.max(
				blushActive ? 1 : 0,
				profile ? profile.cheek * ease : 0,
				(idleProfile.cheek ?? 0) * idleExpressionWeight,
			);
			const mouthForm =
				(profile ? profile.mouthForm * ease : 0) +
				(idleProfile.mouthForm ?? 0) * idleExpressionWeight;
			const brows = profile?.brows;
			const idleBrows = idleProfile.brows;

			setModelParameter(model, ["ParamMouthOpenY", "PARAM_MOUTH_OPEN_Y"], mouthOpen);
			setModelParameter(model, ["ParamEyeLSmile", "ParamEyeRSmile"], eyeSmile);
			setModelParameter(model, ["ParamCheek"], cheek);
			setModelParameter(model, ["ParamMouthForm", "ParamMouthFormScale"], mouthForm);
			setModelParameter(
				model,
				["ParamBrowLY", "ParamBrowRY"],
				(brows?.y ?? 0) * ease +
					(idleBrows?.y ?? 0) * idleExpressionWeight,
			);
			setModelParameter(
				model,
				["ParamBrowLForm", "ParamBrowRForm"],
				(brows?.form ?? 0) * ease +
					(idleBrows?.form ?? 0) * idleExpressionWeight,
			);
			setModelParameter(
				model,
				["ParamBrowLAngle", "ParamBrowRAngle"],
				(brows?.angle ?? 0) * ease +
					(idleBrows?.angle ?? 0) * idleExpressionWeight,
			);
		};

		const syncAccessoryBreathing = (model, t, idleProfile) => {
			const accessoryScale = idleProfile.accessoryScale ?? 1;
			const dollScale = idleProfile.dollScale ?? accessoryScale;
			const wingScale = idleProfile.wingScale ?? accessoryScale;
			const earScale = idleProfile.earScale ?? accessoryScale;
			const wispScale = idleProfile.wispScale ?? accessoryScale;
			const soft = Math.sin(t * 0.64);
			const slow = Math.sin(t * 0.42 + 0.6);
			const offset = Math.sin(t * 0.78 + 1.1);
			const tiny = Math.sin(t * 1.05 + 0.35);

			addModelParameter(model, ["ParamDollX"], soft * 0.9 * dollScale, 0.26);
			addModelParameter(model, ["ParamDollY"], offset * 0.82 * dollScale, 0.26);
			addModelParameter(model, ["ParamDollAngleX"], slow * 1.45 * dollScale, 0.32);
			addModelParameter(model, ["ParamDollAngleY"], soft * 1.15 * dollScale, 0.3);

			const idleWing = Math.sin(t * 0.78) * 0.15 + Math.sin(t * 0.42) * 0.06;
				addModelParameter(
					model,
					[
						"ParamWingLZ",
						"ParamWingLEmoRotation",
					"ParamWingL",
					"ParamWingLRotation",
						"ParamWingLOpen",
					],
					idleWing * wingScale,
					0.16,
				);
				addModelParameter(
					model,
				[
					"ParamWingRZ",
					"ParamWingREmoRotation",
					"ParamWingR",
					"ParamWingRRotation",
						"ParamWingROpen",
					],
					idleWing * wingScale,
					0.16,
				);
				addModelParameter(model, ["ParamWingRotation"], slow * 0.16 * wingScale, 0.13);
				addModelParameter(model, ["ParamWingLY", "ParamWingRY"], offset * 0.18 * wingScale, 0.08);

			addModelParameter(
				model,
				["ParamEarL", "ParamEarRAngleZ"],
				tiny * 0.48 * earScale,
				0.1,
			);
			addModelParameter(model, ["ParamEarR"], -tiny * 0.48 * earScale, 0.1);

			if (!stableSleeveModelIds.has(currentModelId)) {
				addModelParameter(
					model,
					[
						"ParamLeftSleeveRotation",
						"ParamLeftFrontSleeveRotation",
						"ParamLeftSleeveFrontRotation",
						"ParamLeftSleeveRotationZ",
						"ParamLeftFrontSleeveRotationZ",
						"ParamSleeveLeft",
						"ParamSleeveLeftOpen",
						"ParamSleeveMoveL",
						"ParamSleeveZL",
					],
					soft * 0.1 * accessoryScale,
					0.06,
				);
				addModelParameter(
					model,
					[
						"ParamRightSleeveRotation",
						"ParamRightFrontSleeveRotation",
						"ParamRightSleeveFrontRotation",
						"ParamRightSleeveRotationZ",
						"ParamRightFrontSleeveRotationZ",
						"ParamSleeveRight",
						"ParamSleeveRightOpen",
						"ParamSleeveMoveR",
						"ParamSleeveZR",
					],
					-slow * 0.1 * accessoryScale,
					0.06,
				);
				addModelParameter(
					model,
					["ParamSleeveLeftFrontAndBack", "ParamSleeveRightFrontAndBack"],
					offset * 0.09 * accessoryScale,
					0.05,
				);
			}

			addModelParameter(model, ["ParamChainLShake"], soft * 0.44 * accessoryScale, 0.14);
			addModelParameter(model, ["ParamChainRShake"], slow * 0.44 * accessoryScale, 0.14);

			addModelParameter(model, ["ParamWillOTheWhisp1X"], soft * 0.58 * wispScale, 0.12);
			addModelParameter(model, ["ParamWillOTheWhisp1Y"], offset * 0.48 * wispScale, 0.12);
			addModelParameter(model, ["ParamWillOTheWhisp2X"], -slow * 0.54 * wispScale, 0.12);
			addModelParameter(model, ["ParamWillOTheWhisp2Y"], soft * 0.42 * wispScale, 0.12);
			addModelParameter(model, ["ParamWillOTheWhisp3X"], offset * 0.52 * wispScale, 0.12);
			addModelParameter(model, ["ParamWillOTheWhisp3Y"], -slow * 0.45 * wispScale, 0.12);

			addModelParameter(model, ["ParamEyeHiLightShake"], tiny * 0.1 * accessoryScale, 0.05);
		};

		const syncLiveliness = (model, now, profile, speechEase) => {
				const t = (now - idleStartedAt) / 1000;
				const idleProfile = getIdleProfile();
				const idlePoseWeight = Math.max(0.28, 1 - speechEase * 0.72);
				const focusIsFresh = now - pointerFocus.lastAt < 2600;
				const focusTargetX = focusIsFresh ? pointerFocus.targetX : 0;
				const focusTargetY = focusIsFresh ? pointerFocus.targetY : 0;
					pointerFocus.x += (focusTargetX - pointerFocus.x) * 0.16;
					pointerFocus.y += (focusTargetY - pointerFocus.y) * 0.16;
					const trackingWeight = Math.max(0.35, 1 - speechEase * 0.5);
					const facingDirection = getWidgetFacingDirection();
					setModelParameter(model, ["ParamBreath"], 0.5 + Math.sin(t * 1.25) * 0.18);
					addModelParameter(model, ["ParamBodyAngleX"], (idleProfile.bodyX ?? 0) * idlePoseWeight, 0.22);
					addModelParameter(model, ["ParamBodyAngleY"], (idleProfile.bodyY ?? 0) * idlePoseWeight, 0.22);
					addModelParameter(model, ["ParamBodyAngleZ"], (idleProfile.bodyZ ?? 0) * idlePoseWeight, 0.22);
					addModelParameter(model, ["ParamAngleZ"], (idleProfile.angleZ ?? 0) * idlePoseWeight, 0.2);
					addModelParameter(model, ["ParamBodyAngleX"], facingDirection * 1.6 * idlePoseWeight, 0.2);
					addModelParameter(model, ["ParamAngleX"], facingDirection * 5.2 * idlePoseWeight, 0.22);
					addModelParameter(model, ["ParamBodyAngleY"], Math.sin(t * 0.34) * 0.35, 0.28);
				addModelParameter(model, ["ParamBodyAngleZ"], Math.sin(t * 0.42) * 0.26, 0.24);
				addModelParameter(model, ["ParamAngleZ"], Math.sin(t * 0.38) * 0.24, 0.2);
				addModelParameter(model, ["ParamAngleX"], pointerFocus.x * 9.5 * trackingWeight, 0.48);
				addModelParameter(model, ["ParamAngleY"], -pointerFocus.y * 6.5 * trackingWeight, 0.44);
				addModelParameter(model, ["ParamEyeBallX"], pointerFocus.x * 0.68 * trackingWeight, 0.55);
				addModelParameter(model, ["ParamEyeBallY"], -pointerFocus.y * 0.46 * trackingWeight, 0.48);
				syncAccessoryBreathing(model, t, idleProfile);
			if (profile) {
				const wave =
					Math.sin((now - speechProfileStartedAt) / 130 + gestureSeed) * 0.5 +
					0.5;
				const gesture = profile.gesture;
				const pulse = (0.64 + wave * 0.2) * speechEase;

				addModelParameter(model, ["ParamBodyAngleX"], gesture.bodyX * pulse, 0.32);
				addModelParameter(model, ["ParamBodyAngleY"], gesture.bodyY * pulse, 0.32);
				addModelParameter(model, ["ParamBodyAngleZ"], gesture.bodyZ * pulse, 0.32);
				const wingWave =
					Math.sin((now - speechProfileStartedAt) / 170 + gestureSeed) * 0.5 + 0.5;
				const wingPulse = -gesture.wing * (0.42 + wingWave * 0.18) * speechEase;
				addModelParameter(
					model,
					[
						"ParamWingLZ",
						"ParamWingLRotation",
						"ParamWingLEmoRotation",
						"ParamWingL",
						"ParamWingLOpen",
					],
					wingPulse,
					0.28,
				);
				addModelParameter(
					model,
					[
						"ParamWingRZ",
						"ParamWingRRotation",
						"ParamWingREmoRotation",
						"ParamWingR",
						"ParamWingROpen",
					],
					wingPulse,
					0.28,
				);
					addModelParameter(model, ["ParamWingRotation"], -wingPulse * 0.24, 0.2);
					const handWave =
						Math.sin((now - speechProfileStartedAt) / 360 + gestureSeed * 0.7) *
							0.5 +
						0.5;
					const handPulse = (0.22 + handWave * 0.12) * speechEase;
					const wristPulse =
						Math.sin((now - speechProfileStartedAt) / 210 + gestureSeed) *
						0.35 *
						speechEase;
					const leftArmValue = gesture.handL * handPulse;
					const rightArmValue = gesture.handR * handPulse;
					if (!stableSleeveModelIds.has(currentModelId)) {
						addModelParameter(model, ["ParamLeftArmShake"], leftArmValue, 0.055);
						addModelParameter(model, ["ParamRighttArmShake"], rightArmValue, 0.055);
						addModelParameter(
							model,
							["ParamLeftWristRotation", "ParamLeftHandAngle", "ParamHandLAngle"],
							wristPulse + leftArmValue * 0.62,
							0.035,
						);
						addModelParameter(
							model,
							["ParamRightWristRotation", "ParamRightHandAngle", "ParamHandRAngle"],
							-wristPulse + rightArmValue * 0.62,
							0.035,
						);
						addModelParameter(
							model,
							["ParamLeftHandGrip", "ParamHandLOpen", "ParamLeftHandOpen"],
							(0.24 + handWave * 0.24) * speechEase,
							0.08,
						);
						addModelParameter(
							model,
							["ParamRightHandGrip", "ParamHandROpen", "ParamRightHandOpen"],
							(0.2 + (1 - handWave) * 0.22) * speechEase,
							0.08,
						);
					}
					const dollSpeechWave =
						Math.sin((now - speechProfileStartedAt) / 190 + gestureSeed * 0.4) *
						speechEase;
				addModelParameter(model, ["ParamDollX"], dollSpeechWave * 1.2, 0.28);
				addModelParameter(
					model,
					["ParamDollY"],
					Math.cos((now - speechProfileStartedAt) / 230 + gestureSeed) *
						speechEase *
						1.0,
					0.28,
				);
				addModelParameter(model, ["ParamDollAngleX"], dollSpeechWave * 2.4, 0.3);
				addModelParameter(
					model,
					["ParamDollAngleY"],
					Math.sin((now - speechProfileStartedAt) / 260 + gestureSeed) *
						speechEase *
						1.8,
					0.28,
				);
			}

			if (now > nextBlinkAt) {
				blinkUntil = now + 140;
				nextBlinkAt = now + 2400 + Math.random() * 3200;
			}
			if (now < blinkUntil) {
				setModelParameter(model, ["ParamEyeLOpen", "ParamEyeROpen", "ParamEyeOpen"], 0.08);
			}
		};

		const openModelMouth = () => {
			if (!live2dModel) return;

			expressionUntil = Math.max(expressionUntil, performance.now() + 900);
			setModelParameter(live2dModel, ["ParamMouthOpenY", "PARAM_MOUTH_OPEN_Y"], 1);
			setModelParameter(live2dModel, ["ParamEyeLSmile", "ParamEyeRSmile"], 1);
		};

		const getMotionEntries = (motions) =>
			Object.entries(motions ?? {}).flatMap(
				([group, motionList]) =>
					Array.isArray(motionList)
						? motionList.map((motion, index) => ({ group, index, motion }))
						: [],
			);

		const getMotionNumber = (motion) => {
			const file = String(motion?.File ?? motion?.file ?? "");
			const match = file.match(/_(\d+)\.motion3\.json$/i);
			return match ? Number(match[1]) : Number.POSITIVE_INFINITY;
		};

			const shuffleNumbers = (numbers) => {
				const result = [...numbers];
				for (let index = result.length - 1; index > 0; index -= 1) {
					const randomIndex = Math.floor(Math.random() * (index + 1));
					[result[index], result[randomIndex]] = [result[randomIndex], result[index]];
				}
				return result;
			};

			const selectMotionByNumbers = (motionEntries, motionNumbers) => {
				for (const motionNumber of motionNumbers) {
					const entry = motionEntries.find(
						(entry) => getMotionNumber(entry.motion) === motionNumber,
					);
					if (entry) return entry;
				}
				return null;
			};

			const selectPoseMotion = (motions) => {
				const motionEntries = getMotionEntries(motions);
				if (!motionEntries.length) return null;

				const preferenceGroups = preservedDefaultPoseModelIds.has(currentModelId)
					? null
					: characterPoseMotionPreferences[currentModelId];
				if (Array.isArray(preferenceGroups) && preferenceGroups.length) {
					const availableGroups = preferenceGroups
						.map((group) =>
							group.filter((motionNumber) =>
								motionEntries.some(
									(entry) => getMotionNumber(entry.motion) === motionNumber,
								),
							),
						)
						.filter((group) => group.length);
					const selectedGroup =
						availableGroups[Math.floor(Math.random() * availableGroups.length)];
					const selectedMotion = selectedGroup
						? selectMotionByNumbers(motionEntries, shuffleNumbers(selectedGroup))
						: null;
					if (selectedMotion) return selectedMotion;
				}

				const preferredNumbers = [
					1,
					10,
					20,
				21,
				22,
				23,
				24,
				25,
				30,
				31,
				32,
				33,
				34,
				35,
				40,
				41,
				42,
				43,
				44,
				45,
				50,
				51,
				52,
				53,
				54,
					55,
				];
				const preferredMotion = selectMotionByNumbers(motionEntries, preferredNumbers);
				if (preferredMotion) return preferredMotion;

				return motionEntries
					.filter((entry) => getMotionNumber(entry.motion) < 40)
				.sort(
					(a, b) =>
						Math.abs(getMotionNumber(a.motion) - 20) -
						Math.abs(getMotionNumber(b.motion) - 20),
					)[0] ?? motionEntries[0];
			};

			const selectNeutralMotion = (motions) => {
				const motionEntries = getMotionEntries(motions);
				if (!motionEntries.length) return null;
				return (
					selectMotionByNumbers(motionEntries, [1, 2, 3, 4, 5, 6, 7, 8]) ??
					selectMotionByNumbers(motionEntries, [10, 11, 12, 13, 14, 15]) ??
					motionEntries[0]
				);
			};

		const getHandSide = (partId) => {
			const normalized = partId.replace(/[_-]/g, "").toLowerCase();
			if (normalized.includes("lefthand") || normalized.includes("handl")) {
				return "left";
			}
			if (
				normalized.includes("righthand") ||
				normalized.includes("handr") ||
				normalized.includes("rghithand")
			) {
				return "right";
			}
			return null;
		};

		const getCurveStartValue = (curve) => {
			const value = Number(curve?.Segments?.[1]);
			return Number.isFinite(value) ? value : 0;
		};

		const createHandPartLock = (selectedMotionJson, allMotionJsons = []) => {
			const handsBySide = new Map();
			const visibleBySide = new Map();
			const collectCurve = (curve, side, shouldUseVisibleValue) => {
				if (curve?.Target !== "PartOpacity" || typeof curve.Id !== "string") return;

				if (!handsBySide.has(side)) handsBySide.set(side, []);
				const sideParts = handsBySide.get(side);
				if (!sideParts.includes(curve.Id)) sideParts.push(curve.Id);

				const value = getCurveStartValue(curve);
				const current = visibleBySide.get(side);
				if (shouldUseVisibleValue && value > 0.001 && (!current || value > current.value)) {
					visibleBySide.set(side, { id: curve.Id, value });
				}
			};

			for (const motionJson of allMotionJsons) {
				for (const curve of motionJson?.Curves ?? []) {
					const side = getHandSide(curve?.Id ?? "");
					if (!side) continue;
					collectCurve(curve, side, false);
				}
			}

			for (const curve of selectedMotionJson?.Curves ?? []) {
				const side = getHandSide(curve?.Id ?? "");
				if (!side) continue;
				collectCurve(curve, side, true);
			}

				const opacityMap = new Map();
				for (const [side, partIds] of handsBySide) {
					const visibleId = visibleBySide.get(side)?.id;
					if (!visibleId) continue;
					for (const partId of partIds) {
						opacityMap.set(partId, partId === visibleId ? 1 : 0);
					}
			}
			return opacityMap.size ? opacityMap : null;
		};

			const isPoseParameterId = (id) => {
				const isBodyPoseParameter =
					/(arm|shoulder|wrist|sleeve|wing)/i.test(id) &&
					!/drawing/i.test(id);
				const isHandLayerParameter =
					/hand(?:grip|open|angle|order|drawing)/i.test(id);
				const isAccessoryLayerParameter =
					/(doll|chain|whisp|wisp|ear).*order|order.*(doll|chain|whisp|wisp|ear)/i.test(id);
				return (
					(isBodyPoseParameter || isHandLayerParameter || isAccessoryLayerParameter) &&
					!/frill/i.test(id)
				);
			};

			const normalizePoseParameterValue = (id, value) => {
				if (/hand.*(?:order|drawing)|(?:order|drawing).*hand/i.test(id)) {
					return Math.max(value, 0.82);
				}
				return value;
			};

			const createPoseParameterLock = (motionJson) => {
			const parameterMap = new Map();
			for (const curve of motionJson?.Curves ?? []) {
				if (
					curve?.Target !== "Parameter" ||
					typeof curve.Id !== "string" ||
					!isPoseParameterId(curve.Id)
				) {
					continue;
				}
					parameterMap.set(
						curve.Id,
						normalizePoseParameterValue(curve.Id, getCurveStartValue(curve)),
					);
				}
			return parameterMap.size ? parameterMap : null;
		};

			const loadHandPartLock = async (model) => {
				try {
					const settingsResponse = await fetch(model.path);
					if (!settingsResponse.ok) return null;
					const settings = await settingsResponse.json();
					const motions = settings.FileReferences?.Motions;
					const motionEntries = getMotionEntries(motions);
					const selectedMotion = selectPoseMotion(motions);
					const neutralMotion = selectNeutralMotion(motions);
					if (!selectedMotion) return null;

					const fetchMotionJson = async (entry) => {
						const file = entry?.motion?.File ?? entry?.motion?.file;
						if (!file) return null;

						const motionUrl = new URL(file, new URL(model.path, window.location.href));
						const motionResponse = await fetch(motionUrl);
						return motionResponse.ok ? motionResponse.json() : null;
					};

					const motionJson = await fetchMotionJson(selectedMotion);
					const neutralMotionJson = await fetchMotionJson(neutralMotion);
					if (!motionJson) return null;
					const allMotionJsons = (
						await Promise.all(
							motionEntries.map(async (entry) => {
								try {
									return fetchMotionJson(entry);
								} catch {
									return null;
								}
						}),
					)
				).filter(Boolean);
					return {
						lock: createHandPartLock(motionJson, allMotionJsons),
						neutralLock: createHandPartLock(neutralMotionJson, allMotionJsons),
						parameterLock: createPoseParameterLock(motionJson),
						neutralParameterLock: createPoseParameterLock(neutralMotionJson),
						motion: selectedMotion,
						neutralMotion,
					};
			} catch (error) {
				console.debug("Live2D hand pose lock failed:", error);
				return null;
			}
		};

		const getInteractionEvent = (event) => event?.data?.originalEvent ?? event;

		const getClientPoint = (event) => {
			const source = getInteractionEvent(event);
			if (typeof source?.clientX === "number" && typeof source?.clientY === "number") {
				return {
					x: source.clientX,
					y: source.clientY,
				};
			}
			return null;
		};

		const isUpperModelTap = (event) => {
			const point = getClientPoint(event);
			if (!point) return false;
			const rect = canvas.getBoundingClientRect();
			if (!rect.width || !rect.height) return false;

			const xRatio = (point.x - rect.left) / rect.width;
			const yRatio = (point.y - rect.top) / rect.height;
			return xRatio > 0.22 && xRatio < 0.78 && yRatio > 0.05 && yRatio < 0.46;
		};

		const fitModelToWidget = (model, app) => {
			model.scale.set(1);
			model.position.set(0, 0);

			const screenWidth = app.screen.width;
			const screenHeight = app.screen.height;
			const bounds = model.getLocalBounds();
			const modelWidth = Math.max(bounds.width, 1);
			const modelHeight = Math.max(bounds.height, 1);
			const scale = Math.min(
				(screenWidth * 0.94) / modelWidth,
				(screenHeight * 0.97) / modelHeight,
			);

			model.scale.set(scale);
			model.position.set(
				screenWidth / 2 - (bounds.x + bounds.width / 2) * scale,
				screenHeight / 2 - (bounds.y + bounds.height / 2) * scale,
			);
		};

		const triggerLive2DInteraction = (event) => {
			const now = performance.now();
			if (now - lastInteractionAt < 120) return;
			lastInteractionAt = now;
			if (live2dModel) {
				playTapMotion(event);
			} else {
				showBubble();
			}
		};

			canvas.addEventListener("click", triggerLive2DInteraction);
			window.addEventListener("pointermove", (event) => {
				pointerFocus.targetX = clamp((event.clientX / window.innerWidth - 0.5) * 2, -1, 1);
				pointerFocus.targetY = clamp((event.clientY / window.innerHeight - 0.5) * 2, -1, 1);
				pointerFocus.lastAt = performance.now();
				live2dModel?.focus?.(event.clientX, event.clientY);
			});

		const loadModel = async (model = getSelectedModel(), forceReload = false) => {
			if (!model?.path) {
				model = getSelectedModel();
			}
			currentModelId = model.id ?? defaultModelId;
			const loadId = ++modelLoadId;
			if (live2dLoaded && !forceReload) return;
			live2dLoading = true;
			if (forceReload) disposeModel();
			const handPartLockPromise = loadHandPartLock(model);
			widget.classList.remove("live2d-error");
			widget.classList.remove("live2d-ready");
			setStatus("Live2D loading");
			const runtimeReady = await prepareRuntime();
			if (!runtimeReady) {
				if (loadId === modelLoadId) {
					live2dLoading = false;
				}
				return;
			}

			const app = getApp();

			let loadedModel = null;
			try {
				loadedModel = await PIXI.live2d.Live2DModel.from(model.path, {
					autoInteract: false,
				});
				console.debug("Live2D model loaded:", model.path);
			} catch (error) {
				console.debug("Live2D model failed:", model.path, error);
			}

			if (loadId !== modelLoadId) {
				loadedModel?.destroy?.();
				return;
			}

				if (!loadedModel) {
					live2dLoading = false;
					widget.classList.add("live2d-error");
					setStatus("Live2D model failed");
					console.error("Live2D model could not be loaded.", model);
					if (!forceReload && loadId === modelLoadId) {
						window.setTimeout(() => loadModel(model, true), 900);
					}
					return;
				}

			const handPose = await handPartLockPromise;
			if (loadId !== modelLoadId) {
				loadedModel.destroy();
				return;
			}
				disposeModel();
				handPartLock = handPose?.lock ?? null;
				neutralHandPartLock = handPose?.neutralLock ?? null;
				poseParameterLock = handPose?.parameterLock ?? null;
				neutralPoseParameterLock = handPose?.neutralParameterLock ?? null;
				idleStartedAt = performance.now();
				poseStartedAt = performance.now();
				blushUntil = 0;
				expressionUntil = 0;
			loadedModel.interactive = true;
			loadedModel.buttonMode = true;
			loadedModel.on("hit", triggerLive2DInteraction);
			loadedModel.on("pointertap", triggerLive2DInteraction);
			app.stage.addChild(loadedModel);
			widget.classList.add("live2d-ready");
			live2dModel = loadedModel;
			syncPoseParameterLock(loadedModel);
				syncHandPartLock(loadedModel);
				fitModelToWidget(loadedModel, app);
				window.requestAnimationFrame(() => fitModelToWidget(loadedModel, app));
				window.setTimeout(() => fitModelToWidget(loadedModel, app), 2600);
				window.setTimeout(() => fitModelToWidget(loadedModel, app), 3400);

			resizeModel = () => {
				fitModelToWidget(loadedModel, app);
			};
			window.addEventListener("resize", resizeModel);
			live2dLoaded = true;
			live2dLoading = false;
		};

		toggle.addEventListener("click", () => {
			const shouldShow = widget.classList.contains("live2d-hidden");
			setHidden(!shouldShow);
			if (shouldShow) loadModel();
		});

		reset.addEventListener("click", () => {
			localStorage.removeItem(positionStorageKey);
			const position = getDefaultPosition();
			setPosition(position.x, position.bottom, false);
		});

		select.addEventListener("change", () => {
			const selectedModel = modelsById.get(select.value) ?? modelsById.get(defaultModelId);
			if (!selectedModel) return;
			localStorage.setItem(modelStorageKey, selectedModel.id);
			if (!widget.classList.contains("live2d-hidden")) {
				loadModel(selectedModel, true);
			}
		});

		widget.addEventListener("pointerdown", (event) => {
			if (event.target.closest("button, a, select")) return;

			const rect = widget.getBoundingClientRect();
			dragState = {
				pointerId: event.pointerId,
				offsetX: event.clientX - rect.left,
				startX: event.clientX,
				startY: event.clientY,
				moved: false,
			};
			widget.classList.add("live2d-dragging");
			widget.setPointerCapture(event.pointerId);
		});

		widget.addEventListener("pointermove", (event) => {
			if (!dragState || dragState.pointerId !== event.pointerId) return;
			event.preventDefault();
			const distance = Math.hypot(
				event.clientX - dragState.startX,
				event.clientY - dragState.startY,
			);
			if (distance > 5) {
				dragState.moved = true;
			}
			setPosition(event.clientX - dragState.offsetX, bottomOffset);
		});

		const endDrag = (event) => {
			if (!dragState || dragState.pointerId !== event.pointerId) return;
			const wasTap = !dragState.moved;
			dragState = null;
			widget.classList.remove("live2d-dragging");
			try {
				widget.releasePointerCapture(event.pointerId);
			} catch {
				// Pointer capture may already be released by the browser.
			}
			if (wasTap && !event.target.closest("button, a, select")) {
				triggerLive2DInteraction(event);
			}
		};

		widget.addEventListener("pointerup", endDrag);
		widget.addEventListener("pointercancel", endDrag);

		window.addEventListener("resize", () => {
			const rect = widget.getBoundingClientRect();
			setPosition(rect.left, bottomOffset, false);
		});

		const recoverLive2D = () => {
			if (widget.classList.contains("live2d-hidden")) return;

			if (live2dModel && live2dApp) {
				live2dApp.ticker.start();
				fitModelToWidget(live2dModel, live2dApp);
				widget.classList.add("live2d-ready");
				widget.classList.remove("live2d-error");
				return;
			}

			if (!live2dLoading) {
				loadModel(getSelectedModel(), true);
			}
		};
		globalState.recover = recoverLive2D;

		window.addEventListener("pageshow", recoverLive2D);
		document.addEventListener("visibilitychange", () => {
			if (!document.hidden) {
				recoverLive2D();
			}
		});

		const registerSwupRecovery = () => {
			window.swup?.hooks?.on?.("page:view", recoverLive2D);
		};

		if (window.swup?.hooks) {
			registerSwupRecovery();
		} else {
			document.addEventListener("swup:enable", registerSwupRecovery, {
				once: true,
			});
		}

		restorePosition();
		syncModelSelect();

		if (localStorage.getItem("live2d-hidden") === "true") {
			setHidden(true);
			return;
		}

			const queueInitialLoad = () => {
				const startLoad = () => loadModel();
				window.setTimeout(startLoad, 120);
			};

		if (document.readyState === "complete" || document.readyState === "interactive") {
			queueInitialLoad();
		} else {
			window.addEventListener("load", queueInitialLoad, { once: true });
		}
	})();
</script>
