<div id="live2d-widget" aria-label="Live2D model">
	<button id="live2d-toggle" type="button" aria-label="Hide Live2D model">
		<span aria-hidden="true">×</span>
	</button>
	<button id="live2d-reset" type="button" aria-label="Reset Live2D position">
		R
	</button>
	<select id="live2d-model-select" aria-label="Select Live2D model">
		{modelOptions.map((model) => (
			<option value={model.id} selected={model.id === "remilia-event"}>
				{model.name}
			</option>
		))}
	</select>
	<canvas id="live2d-canvas"></canvas>
	<div id="live2d-status" aria-live="polite">Live2D loading</div>
	<div id="live2d-bubble" aria-live="polite"></div>
	<a
		id="live2d-credit"
		href="https://github.com/n0099/TouhouCannonBall-Live2d-Models/tree/main/Remilia%20(Event)"
		target="_blank"
		rel="noopener"
	>
		Live2D
	</a>
</div>

<style>
	#live2d-widget {
		position: fixed;
		left: max(0.75rem, env(safe-area-inset-left));
		bottom: max(0.75rem, env(safe-area-inset-bottom));
		z-index: 60;
		width: clamp(150px, 15vw, 230px);
		height: clamp(225px, 24.5vw, 345px);
		pointer-events: none;
		opacity: 0.78;
		transform: translateY(0.75rem);
		touch-action: none;
		user-select: none;
		transition:
			opacity 0.35s ease,
			transform 0.35s ease;
	}

	#live2d-widget.live2d-dragging,
	#live2d-widget.live2d-ready {
		opacity: 0.92;
		transform: translateY(0);
	}

	#live2d-widget.live2d-dragging {
		transition: opacity 0.2s ease;
	}

	#live2d-widget.live2d-tapped {
		animation: live2d-tap-pulse 0.26s ease;
	}

	#live2d-widget.live2d-error {
		width: 8.5rem;
		height: 3rem;
		opacity: 0.82;
		transform: translateY(0);
	}

	#live2d-widget.live2d-hidden {
		width: 2.5rem;
		height: 2.5rem;
		opacity: 0.72;
		transform: translateY(0);
	}

	#live2d-canvas {
		display: block;
		width: 100%;
		height: 100%;
		pointer-events: auto;
		cursor: grab;
	}

	#live2d-widget.live2d-dragging #live2d-canvas {
		cursor: grabbing;
	}

	#live2d-status {
		position: absolute;
		left: 50%;
		top: 50%;
		transform: translate(-50%, -50%);
		border-radius: 999px;
		background: rgba(0, 0, 0, 0.42);
		padding: 0.25rem 0.625rem;
		color: rgba(255, 255, 255, 0.84);
		font-size: 0.68rem;
		white-space: nowrap;
		pointer-events: none;
	}

	#live2d-widget.live2d-ready #live2d-status {
		display: none;
	}

	#live2d-bubble {
		position: absolute;
		left: 0.25rem;
		bottom: calc(100% + 0.35rem);
		max-width: min(15rem, 80vw);
		border: 1px solid rgba(255, 255, 255, 0.28);
		border-radius: 0.75rem;
		background: color-mix(in oklch, var(--card-bg) 86%, transparent);
		box-shadow: 0 0.5rem 1.75rem rgba(0, 0, 0, 0.18);
		color: rgba(0, 0, 0, 0.9);
		font-size: 0.78rem;
		line-height: 1.45;
		opacity: 0;
		padding: 0.55rem 0.75rem;
		pointer-events: none;
		transform: translateY(0.4rem);
		transition:
			opacity 0.2s ease,
			transform 0.2s ease;
		width: max-content;
		z-index: 80;
	}

	:global(.dark) #live2d-bubble {
		color: rgba(255, 255, 255, 0.9);
	}

	#live2d-bubble.live2d-bubble-active {
		opacity: 1;
		transform: translateY(0);
	}

	#live2d-toggle,
	#live2d-reset,
	#live2d-model-select,
	#live2d-credit {
		position: absolute;
		pointer-events: auto;
		opacity: 0;
		transition: opacity 0.2s ease;
	}

	#live2d-widget:hover #live2d-toggle,
	#live2d-widget:hover #live2d-reset,
	#live2d-widget:hover #live2d-model-select,
	#live2d-widget:hover #live2d-credit {
		opacity: 1;
	}

	#live2d-widget.live2d-hidden #live2d-canvas,
	#live2d-widget.live2d-hidden #live2d-status,
	#live2d-widget.live2d-hidden #live2d-bubble,
	#live2d-widget.live2d-hidden #live2d-reset,
	#live2d-widget.live2d-hidden #live2d-model-select,
	#live2d-widget.live2d-hidden #live2d-credit {
		display: none;
	}

	#live2d-widget.live2d-hidden #live2d-toggle {
		top: 0;
		right: 0;
		width: 100%;
		height: 100%;
		opacity: 1;
		font-size: 0.72rem;
		font-weight: 700;
	}

	#live2d-toggle {
		top: 0.25rem;
		right: 0.25rem;
	}

	#live2d-reset {
		top: 0.25rem;
		right: 2.1rem;
	}

	#live2d-model-select {
		top: 2.1rem;
		right: 0.25rem;
		max-width: min(8.5rem, calc(100% - 0.5rem));
		border-radius: 999px;
		border: 0;
		background: rgba(0, 0, 0, 0.45);
		color: white;
		font-size: 0.68rem;
		padding: 0.25rem 1.4rem 0.25rem 0.55rem;
	}

	#live2d-model-select option {
		color: black;
	}

	#live2d-toggle,
	#live2d-reset {
		width: 1.6rem;
		height: 1.6rem;
		border-radius: 999px;
		background: rgba(0, 0, 0, 0.45);
		color: white;
		font-size: 0.85rem;
		line-height: 1;
	}

	#live2d-credit {
		left: 50%;
		bottom: 0;
		transform: translateX(-50%);
		border-radius: 999px;
		background: rgba(0, 0, 0, 0.42);
		padding: 0.125rem 0.5rem;
		color: rgba(255, 255, 255, 0.82);
		font-size: 0.68rem;
		text-decoration: none;
	}

	@media (max-width: 1023px) {
		#live2d-widget {
			display: none;
		}
	}

	@keyframes live2d-tap-pulse {
		0% {
			filter: brightness(1);
		}

		50% {
			filter: brightness(1.12);
		}

		100% {
			filter: brightness(1);
		}
	}
</style>

