---
import live2dMessages from "../live2d/messages/messages.json";
import { url } from "../utils/url-utils";

const modelOptions = [
	{
		id: "remilia-event",
		name: "Remilia (Event)",
		path: "/model/Remilia (Event)/object_live2d_010_501.asset/object_live2d_010_501.asset.model3.json",
	},
	{
		id: "remilia",
		name: "Remilia",
		path: "/model/Remilia/object_live2d_010_101.asset/object_live2d_010_101.asset.model3.json",
	},
	{
		id: "flandre-event",
		name: "Flandre (Event)",
		path: "/model/Flandre (Event)/object_live2d_011_501.asset/object_live2d_011_501.asset.model3.json",
	},
	{
		id: "flandre",
		name: "Flandre",
		path: "/model/Flandre/object_live2d_011_101.asset/object_live2d_011_101.asset.model3.json",
	},
	{
		id: "cirno-event",
		name: "Cirno (Event)",
		path: "/model/Cirno (Event)/object_live2d_005_501.asset/object_live2d_005_501.asset.model3.json",
	},
	{
		id: "cirno",
		name: "Cirno",
		path: "/model/Cirno/object_live2d_005_101.asset/object_live2d_005_101.asset.model3.json",
	},
	{
		id: "koishi",
		name: "Koishi",
		path: "/model/Koishi/object_live2d_054_101.asset/object_live2d_054_101.asset.model3.json",
	},
	{
		id: "mystia",
		name: "Mystia",
		path: "/model/Mystia/object_live2d_025_101.asset/object_live2d_025_101.asset.model3.json",
	},
];

const modelData = modelOptions.map((model) => ({
	...model,
	path: encodeURI(url(model.path)),
}));
---

<div id="live2d-widget" aria-label="Live2D model">
	<button id="live2d-toggle" type="button" aria-label="Hide Live2D model">
		<span aria-hidden="true">×</span>
	</button>
	<button id="live2d-reset" type="button" aria-label="Reset Live2D position">
		R
	</button>
	<select id="live2d-model-select" aria-label="Select Live2D model">
		{modelOptions.map((model) => (
			<option value={model.id} selected={model.id === "remilia-event"}>
				{model.name}
			</option>
		))}
	</select>
	<canvas id="live2d-canvas"></canvas>
	<div id="live2d-status" aria-live="polite">Live2D loading</div>
	<div id="live2d-bubble" aria-live="polite"></div>
	<a
		id="live2d-credit"
		href="https://github.com/n0099/TouhouCannonBall-Live2d-Models/tree/main/Remilia%20(Event)"
		target="_blank"
		rel="noopener"
	>
		Live2D
	</a>
</div>

<style>
	#live2d-widget {
		position: fixed;
		left: max(0.75rem, env(safe-area-inset-left));
		bottom: max(0.75rem, env(safe-area-inset-bottom));
		z-index: 60;
		width: clamp(120px, 13vw, 190px);
		height: clamp(170px, 20vw, 270px);
		pointer-events: none;
		opacity: 0.78;
		transform: translateY(0.75rem);
		touch-action: none;
		user-select: none;
		transition:
			opacity 0.35s ease,
			transform 0.35s ease;
	}

	#live2d-widget.live2d-dragging,
	#live2d-widget.live2d-ready {
		opacity: 0.92;
		transform: translateY(0);
	}

	#live2d-widget.live2d-dragging {
		transition: opacity 0.2s ease;
	}

	#live2d-widget.live2d-error {
		width: 8.5rem;
		height: 3rem;
		opacity: 0.82;
		transform: translateY(0);
	}

	#live2d-widget.live2d-hidden {
		width: 2.5rem;
		height: 2.5rem;
		opacity: 0.72;
		transform: translateY(0);
	}

	#live2d-canvas {
		display: block;
		width: 100%;
		height: 100%;
		pointer-events: auto;
		cursor: grab;
	}

	#live2d-widget.live2d-dragging #live2d-canvas {
		cursor: grabbing;
	}

	#live2d-status {
		position: absolute;
		left: 50%;
		top: 50%;
		transform: translate(-50%, -50%);
		border-radius: 999px;
		background: rgba(0, 0, 0, 0.42);
		padding: 0.25rem 0.625rem;
		color: rgba(255, 255, 255, 0.84);
		font-size: 0.68rem;
		white-space: nowrap;
		pointer-events: none;
	}

	#live2d-widget.live2d-ready #live2d-status {
		display: none;
	}

	#live2d-bubble {
		position: absolute;
		left: 0.25rem;
		bottom: calc(100% + 0.35rem);
		max-width: min(15rem, 80vw);
		border: 1px solid rgba(255, 255, 255, 0.28);
		border-radius: 0.75rem;
		background: color-mix(in oklch, var(--card-bg) 86%, transparent);
		box-shadow: 0 0.5rem 1.75rem rgba(0, 0, 0, 0.18);
		color: rgba(0, 0, 0, 0.9);
		font-size: 0.78rem;
		line-height: 1.45;
		opacity: 0;
		padding: 0.55rem 0.75rem;
		pointer-events: none;
		transform: translateY(0.4rem);
		transition:
			opacity 0.2s ease,
			transform 0.2s ease;
		width: max-content;
		z-index: 80;
	}

	:global(.dark) #live2d-bubble {
		color: rgba(255, 255, 255, 0.9);
	}

	#live2d-bubble.live2d-bubble-active {
		opacity: 1;
		transform: translateY(0);
	}

	#live2d-toggle,
	#live2d-reset,
	#live2d-model-select,
	#live2d-credit {
		position: absolute;
		pointer-events: auto;
		opacity: 0;
		transition: opacity 0.2s ease;
	}

	#live2d-widget:hover #live2d-toggle,
	#live2d-widget:hover #live2d-reset,
	#live2d-widget:hover #live2d-model-select,
	#live2d-widget:hover #live2d-credit {
		opacity: 1;
	}

	#live2d-widget.live2d-hidden #live2d-canvas,
	#live2d-widget.live2d-hidden #live2d-status,
	#live2d-widget.live2d-hidden #live2d-bubble,
	#live2d-widget.live2d-hidden #live2d-reset,
	#live2d-widget.live2d-hidden #live2d-model-select,
	#live2d-widget.live2d-hidden #live2d-credit {
		display: none;
	}

	#live2d-widget.live2d-hidden #live2d-toggle {
		top: 0;
		right: 0;
		width: 100%;
		height: 100%;
		opacity: 1;
		font-size: 0.72rem;
		font-weight: 700;
	}

	#live2d-toggle {
		top: 0.25rem;
		right: 0.25rem;
	}

	#live2d-reset {
		top: 0.25rem;
		right: 2.1rem;
	}

	#live2d-model-select {
		top: 2.1rem;
		right: 0.25rem;
		max-width: min(8.5rem, calc(100% - 0.5rem));
		border-radius: 999px;
		border: 0;
		background: rgba(0, 0, 0, 0.45);
		color: white;
		font-size: 0.68rem;
		padding: 0.25rem 1.4rem 0.25rem 0.55rem;
	}

	#live2d-model-select option {
		color: black;
	}

	#live2d-toggle,
	#live2d-reset {
		width: 1.6rem;
		height: 1.6rem;
		border-radius: 999px;
		background: rgba(0, 0, 0, 0.45);
		color: white;
		font-size: 0.85rem;
		line-height: 1;
	}

	#live2d-credit {
		left: 50%;
		bottom: 0;
		transform: translateX(-50%);
		border-radius: 999px;
		background: rgba(0, 0, 0, 0.42);
		padding: 0.125rem 0.5rem;
		color: rgba(255, 255, 255, 0.82);
		font-size: 0.68rem;
		text-decoration: none;
	}

	@media (max-width: 1023px) {
		#live2d-widget {
			display: none;
		}
	}
</style>

<script
	is:inline
	define:vars={{
		live2dMessages,
		modelData,
	}}
>
	(() => {
		const widget = document.getElementById("live2d-widget");
		const canvas = document.getElementById("live2d-canvas");
		const toggle = document.getElementById("live2d-toggle");
		const reset = document.getElementById("live2d-reset");
		const select = document.getElementById("live2d-model-select");
		const status = document.getElementById("live2d-status");
		const bubble = document.getElementById("live2d-bubble");

		if (!widget || !canvas || !toggle || !reset || !select || !status || !bubble || window.matchMedia("(max-width: 1023px)").matches) {
			return;
		}

		const positionStorageKey = "live2d-position";
		const modelStorageKey = "live2d-model";
		const defaultModelId = "remilia-event";
		const modelsById = new Map(modelData.map((model) => [model.id, model]));
		let live2dLoaded = false;
		let live2dLoading = false;
		let live2dRuntimeReady = false;
		let live2dApp = null;
		let live2dModel = null;
		let resizeModel = null;
		let dragState = null;
		let bubbleTimer = 0;

		const getDefaultPosition = () => ({
			x: Math.max(12, window.innerWidth * 0.012),
			y: Math.max(12, window.innerHeight - widget.offsetHeight - 12),
		});

		const clampPosition = (x, y) => {
			const margin = 8;
			const maxX = Math.max(margin, window.innerWidth - widget.offsetWidth - margin);
			const maxY = Math.max(margin, window.innerHeight - widget.offsetHeight - margin);
			return {
				x: Math.min(Math.max(x, margin), maxX),
				y: Math.min(Math.max(y, margin), maxY),
			};
		};

		const setPosition = (x, y, shouldStore = true) => {
			const position = clampPosition(x, y);
			widget.style.left = `${position.x}px`;
			widget.style.top = `${position.y}px`;
			widget.style.right = "auto";
			widget.style.bottom = "auto";
			if (shouldStore) {
				localStorage.setItem(positionStorageKey, JSON.stringify(position));
			}
		};

		const restorePosition = () => {
			try {
				const stored = JSON.parse(localStorage.getItem(positionStorageKey) || "null");
				if (
					stored &&
					typeof stored.x === "number" &&
					typeof stored.y === "number"
				) {
					setPosition(stored.x, stored.y, false);
					return;
				}
			} catch {
				localStorage.removeItem(positionStorageKey);
			}
			const position = getDefaultPosition();
			setPosition(position.x, position.y, false);
		};

		const setHidden = (hidden) => {
			widget.classList.toggle("live2d-hidden", hidden);
			toggle.textContent = hidden ? "L2D" : "×";
			toggle.setAttribute(
				"aria-label",
				hidden ? "Show Live2D model" : "Hide Live2D model",
			);
			localStorage.setItem("live2d-hidden", hidden ? "true" : "false");
			restorePosition();
		};

		const setStatus = (message) => {
			status.textContent = message;
		};

		const getCurrentLanguage = () =>
			document.documentElement.dataset.language === "en" ? "en" : "zh";

		const showBubble = () => {
			const message =
				live2dMessages[Math.floor(Math.random() * live2dMessages.length)];
			if (!message) return;

			bubble.textContent = message[getCurrentLanguage()] || message.zh;
			bubble.classList.add("live2d-bubble-active");
			window.requestAnimationFrame(() => {
				const bubbleRect = bubble.getBoundingClientRect();
				const widgetRect = widget.getBoundingClientRect();
				let offsetX = 0;

				if (bubbleRect.left < 8) {
					offsetX = 8 - bubbleRect.left;
				} else if (bubbleRect.right > window.innerWidth - 8) {
					offsetX = window.innerWidth - 8 - bubbleRect.right;
				}

				bubble.style.left = `${4 + offsetX}px`;
				if (bubbleRect.top < 8) {
					bubble.style.bottom = "auto";
					bubble.style.top = `${Math.max(4, widgetRect.height * 0.08)}px`;
				} else {
					bubble.style.top = "auto";
					bubble.style.bottom = "calc(100% + 0.35rem)";
				}
			});
			window.clearTimeout(bubbleTimer);
			bubbleTimer = window.setTimeout(() => {
				bubble.classList.remove("live2d-bubble-active");
			}, 3600);
		};

		const getSelectedModel = () => {
			const storedModelId = localStorage.getItem(modelStorageKey);
			return modelsById.get(storedModelId) ?? modelsById.get(defaultModelId) ?? modelData[0];
		};

		const syncModelSelect = () => {
			const selectedModel = getSelectedModel();
			select.value = selectedModel.id;
		};

		const loadScript = (src) =>
			new Promise((resolve, reject) => {
				const existing = document.querySelector(`script[src="${src}"]`);
				if (existing) {
					existing.addEventListener("load", resolve, { once: true });
					existing.addEventListener("error", reject, { once: true });
					if (existing.dataset.loaded === "true") resolve();
					return;
				}

				const script = document.createElement("script");
				script.src = src;
				script.async = true;
				script.onload = () => {
					script.dataset.loaded = "true";
					resolve();
				};
				script.onerror = reject;
				document.head.appendChild(script);
			});

		const disposeModel = () => {
			if (live2dModel) {
				live2dApp?.stage.removeChild(live2dModel);
				live2dModel.destroy();
				live2dModel = null;
			}
			if (resizeModel) {
				window.removeEventListener("resize", resizeModel);
				resizeModel = null;
			}
			live2dLoaded = false;
		};

		const prepareRuntime = async () => {
			if (live2dRuntimeReady) return true;
			try {
				await loadScript("https://cdn.jsdelivr.net/npm/pixi.js@6.5.10/dist/browser/pixi.min.js");
				window.PIXI = PIXI;
				await loadScript("https://cubism.live2d.com/sdk-web/cubismcore/live2dcubismcore.min.js");
				await loadScript("https://cdn.jsdelivr.net/npm/pixi-live2d-display@0.4.0/dist/cubism4.min.js");
				live2dRuntimeReady = true;
				return true;
			} catch (error) {
				widget.classList.add("live2d-error");
				setStatus("Live2D CDN failed");
				console.error("Live2D SDK failed to load:", error);
				return false;
			}
		};

		const getApp = () => {
			if (!live2dApp) {
				live2dApp = new PIXI.Application({
					view: canvas,
					autoStart: true,
					backgroundAlpha: 0,
					antialias: true,
					autoDensity: true,
					resolution: Math.min(window.devicePixelRatio || 1, 2),
					resizeTo: widget,
				});
			}
			return live2dApp;
		};

		const playTapMotion = (model) => {
			setStatus("Live2D touched");
			showBubble();
			window.setTimeout(() => {
				if (widget.classList.contains("live2d-ready")) {
					setStatus("Live2D ready");
				}
			}, 900);

			for (const motionGroup of ["TapBody", "tap_body", ""]) {
				try {
					const result = model.motion(motionGroup);
					if (result) return;
				} catch {
					// Try the next common motion group.
				}
			}
		};

		const fitModelToWidget = (model, app) => {
			model.scale.set(1);
			model.anchor?.set?.(0.5, 0.5);

			const screenWidth = app.screen.width;
			const screenHeight = app.screen.height;
			const modelWidth = Math.max(model.width, 1);
			const modelHeight = Math.max(model.height, 1);
			const scale = Math.min(
				(screenWidth * 0.88) / modelWidth,
				(screenHeight * 0.92) / modelHeight,
			);

			model.scale.set(scale);
			model.position.set(screenWidth / 2, screenHeight / 2);
		};

		const triggerLive2DInteraction = () => {
			if (live2dModel) {
				playTapMotion(live2dModel);
			} else {
				showBubble();
			}
		};

		canvas.addEventListener("click", triggerLive2DInteraction);

		const loadModel = async (model = getSelectedModel(), forceReload = false) => {
			if (live2dLoading) return;
			if (live2dLoaded && !forceReload) return;
			live2dLoading = true;
			if (forceReload) disposeModel();
			widget.classList.remove("live2d-error");
			widget.classList.remove("live2d-ready");
			setStatus("Live2D loading");
			const runtimeReady = await prepareRuntime();
			if (!runtimeReady) {
				live2dLoading = false;
				return;
			}

			const app = getApp();

			let loadedModel = null;
			try {
				loadedModel = await PIXI.live2d.Live2DModel.from(model.path, {
					autoInteract: true,
				});
				console.debug("Live2D model loaded:", model.path);
			} catch (error) {
				console.debug("Live2D model failed:", model.path, error);
			}

			if (!loadedModel) {
				live2dLoading = false;
				widget.classList.add("live2d-error");
				setStatus("Live2D model failed");
				console.error("Live2D model could not be loaded.", model);
				return;
			}

			disposeModel();
			fitModelToWidget(loadedModel, app);
			loadedModel.interactive = true;
			loadedModel.buttonMode = true;
			loadedModel.on("hit", () => playTapMotion(loadedModel));
			loadedModel.on("pointertap", () => playTapMotion(loadedModel));
			app.stage.addChild(loadedModel);
			widget.classList.add("live2d-ready");
			live2dModel = loadedModel;

			resizeModel = () => {
				fitModelToWidget(loadedModel, app);
			};
			window.addEventListener("resize", resizeModel);
			live2dLoaded = true;
			live2dLoading = false;
		};

		toggle.addEventListener("click", () => {
			const shouldShow = widget.classList.contains("live2d-hidden");
			setHidden(!shouldShow);
			if (shouldShow) loadModel();
		});

		reset.addEventListener("click", () => {
			localStorage.removeItem(positionStorageKey);
			const position = getDefaultPosition();
			setPosition(position.x, position.y, false);
		});

		select.addEventListener("change", () => {
			const selectedModel = modelsById.get(select.value) ?? modelsById.get(defaultModelId);
			if (!selectedModel) return;
			localStorage.setItem(modelStorageKey, selectedModel.id);
			if (!widget.classList.contains("live2d-hidden")) {
				loadModel(selectedModel, true);
			}
		});

		widget.addEventListener("pointerdown", (event) => {
			if (event.target.closest("button, a, select")) return;

			const rect = widget.getBoundingClientRect();
			dragState = {
				pointerId: event.pointerId,
				offsetX: event.clientX - rect.left,
				offsetY: event.clientY - rect.top,
				startX: event.clientX,
				startY: event.clientY,
				moved: false,
			};
			widget.classList.add("live2d-dragging");
			widget.setPointerCapture(event.pointerId);
		});

		widget.addEventListener("pointermove", (event) => {
			if (!dragState || dragState.pointerId !== event.pointerId) return;
			event.preventDefault();
			const distance = Math.hypot(
				event.clientX - dragState.startX,
				event.clientY - dragState.startY,
			);
			if (distance > 5) {
				dragState.moved = true;
			}
			setPosition(event.clientX - dragState.offsetX, event.clientY - dragState.offsetY);
		});

		const endDrag = (event) => {
			if (!dragState || dragState.pointerId !== event.pointerId) return;
			const wasTap = !dragState.moved;
			dragState = null;
			widget.classList.remove("live2d-dragging");
			try {
				widget.releasePointerCapture(event.pointerId);
			} catch {
				// Pointer capture may already be released by the browser.
			}
			if (wasTap && !event.target.closest("button, a, select")) {
				triggerLive2DInteraction();
			}
		};

		widget.addEventListener("pointerup", endDrag);
		widget.addEventListener("pointercancel", endDrag);

		window.addEventListener("resize", () => {
			const rect = widget.getBoundingClientRect();
			setPosition(rect.left, rect.top, false);
		});

		restorePosition();
		syncModelSelect();

		if (localStorage.getItem("live2d-hidden") === "true") {
			setHidden(true);
			return;
		}

		const queueInitialLoad = () => {
			window.requestIdleCallback?.(loadModel) ?? window.setTimeout(loadModel, 800);
		};

		if (document.readyState === "complete" || document.readyState === "interactive") {
			queueInitialLoad();
		} else {
			window.addEventListener("load", queueInitialLoad, { once: true });
		}
	})();
</script>
