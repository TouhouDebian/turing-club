---
import { Icon } from "astro-icon/components";
import {
	getCategoryList,
	getSortedPosts,
	getTagList,
} from "../../utils/content-utils";
import WidgetLayout from "./WidgetLayout.astro";

interface Props {
	class?: string;
	style?: string;
}

const className = Astro.props.class;
const style = Astro.props.style;

const siteStartDate = new Date("2026-06-29T00:00:00+08:00");
const now = new Date();
const runningDays = Math.max(
	0,
	Math.floor((now.getTime() - siteStartDate.getTime()) / 86_400_000),
);

const formatRunningTime = (totalDays: number, language: "zh" | "en") => {
	const years = Math.floor(totalDays / 365);
	const daysAfterYears = totalDays % 365;
	const months = Math.floor(daysAfterYears / 30);
	const days = daysAfterYears % 30;

	if (language === "zh") {
		if (years > 0) return `${years}年${months}个月${days}天`;
		if (months > 0) return `${months}个月${days}天`;
		return `${days}天`;
	}

	const unit = (value: number, singular: string, plural = `${singular}s`) =>
		`${value} ${value === 1 ? singular : plural}`;
	if (years > 0) {
		return `${unit(years, "year")} ${unit(months, "month")} ${unit(days, "day")}`;
	}
	if (months > 0) return `${unit(months, "month")} ${unit(days, "day")}`;
	return unit(days, "day");
};

const posts = await getSortedPosts();
const categories = await getCategoryList();
const tags = await getTagList();
const renderedPosts = await Promise.all(posts.map((post) => post.render()));
const totalWords = renderedPosts.reduce(
	(sum, post) => sum + (post.remarkPluginFrontmatter?.words ?? 0),
	0,
);

const stats = [
	{
		icon: "material-symbols:article-outline-rounded",
		zhLabel: "文章数",
		enLabel: "Posts",
		value: String(posts.length),
	},
	{
		icon: "material-symbols:folder-open-outline-rounded",
		zhLabel: "分类数",
		enLabel: "Categories",
		value: String(categories.length),
	},
	{
		icon: "material-symbols:tag-rounded",
		zhLabel: "标签数",
		enLabel: "Tags",
		value: String(tags.length),
	},
	{
		icon: "material-symbols:match-word-rounded",
		zhLabel: "总字数",
		enLabel: "Words",
		value: totalWords.toLocaleString("en-US"),
	},
	{
		icon: "material-symbols:calendar-clock-outline-rounded",
		zhLabel: "运营时长",
		enLabel: "Running",
		value: "",
		zhValue: formatRunningTime(runningDays, "zh"),
		enValue: formatRunningTime(runningDays, "en"),
		isRunningTime: true,
	},
];
---

<WidgetLayout name="状态" id="statistics" class={className} style={style}>
    <div class="flex flex-col gap-1">
        {stats.map((item) => (
            <div class="flex items-center justify-between h-7 px-2 text-neutral-700 dark:text-neutral-300">
                <div class="flex items-center min-w-0">
                    <Icon name={item.icon} class="text-[1.4rem] mr-2 shrink-0"></Icon>
                    <span class="truncate">
                        <span class="lang-zh">{item.zhLabel}</span>
                        <span class="lang-en">{item.enLabel}</span>
                    </span>
                </div>
				<span
					class="font-semibold text-[var(--primary)] tabular-nums"
					data-running-time={item.isRunningTime ? "" : undefined}
					data-start-date={item.isRunningTime ? siteStartDate.toISOString() : undefined}
				>
					{item.isRunningTime ? (
						<>
							<span class="lang-zh" data-running-value="zh">{item.zhValue}</span>
							<span class="lang-en" data-running-value="en">{item.enValue}</span>
						</>
					) : item.value}
				</span>
            </div>
        ))}
    </div>
</WidgetLayout>

<script>
	const updateRunningTime = () => {
		const container = document.querySelector<HTMLElement>("[data-running-time]");
		if (!container?.dataset.startDate) return;

		const startTime = new Date(container.dataset.startDate).getTime();
		const totalDays = Math.max(
			0,
			Math.floor((Date.now() - startTime) / 86_400_000),
		);
		const years = Math.floor(totalDays / 365);
		const daysAfterYears = totalDays % 365;
		const months = Math.floor(daysAfterYears / 30);
		const days = daysAfterYears % 30;
		const unit = (value: number, singular: string) =>
			`${value} ${value === 1 ? singular : `${singular}s`}`;

		const zhValue =
			years > 0
				? `${years}年${months}个月${days}天`
				: months > 0
					? `${months}个月${days}天`
					: `${days}天`;
		const enValue =
			years > 0
				? `${unit(years, "year")} ${unit(months, "month")} ${unit(days, "day")}`
				: months > 0
					? `${unit(months, "month")} ${unit(days, "day")}`
					: unit(days, "day");

		const zhElement = container.querySelector<HTMLElement>(
			'[data-running-value="zh"]',
		);
		const enElement = container.querySelector<HTMLElement>(
			'[data-running-value="en"]',
		);
		if (zhElement) zhElement.textContent = zhValue;
		if (enElement) enElement.textContent = enValue;
	};

	updateRunningTime();
	document.addEventListener("astro:page-load", updateRunningTime);
</script>
