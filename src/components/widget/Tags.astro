---
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import { getTagList } from "../../utils/content-utils";
import { getTagUrl } from "../../utils/url-utils";
import ButtonTag from "../control/ButtonTag.astro";
import WidgetLayout from "./WidgetLayout.astro";

const tags = await getTagList();

interface Props {
	class?: string;
	style?: string;
}
const className = Astro.props.class;
const style = Astro.props.style;
---
<WidgetLayout name={i18n(I18nKey.tags)} id="tags" class={className} style={style}>
    <random-tag-list class="block">
        <div class="tag-scroll-window">
            <div class="flex gap-2 flex-wrap pb-1 pr-1">
                {tags.map(t => (
                    <ButtonTag href={getTagUrl(t.name)} label={`View all posts with the ${t.name.trim()} tag`}>
                        {t.name.trim()}
                    </ButtonTag>
                ))}
            </div>
        </div>
		<button type="button" class="tag-random btn-plain rounded-lg w-full h-9 mt-3" disabled={tags.length === 0}>
			<div class="text-[var(--primary)] flex items-center justify-center gap-2">
				<span>random</span>
			</div>
		</button>
    </random-tag-list>
</WidgetLayout>

<style>
    .tag-scroll-window {
        --tag-window-height: 7.25rem;
        max-height: var(--tag-window-height);
        overflow-y: auto;
        padding-right: 0.25rem;
        scrollbar-width: thin;
        scrollbar-color: color-mix(in oklch, var(--primary) 72%, transparent) transparent;
    }

    .tag-scroll-window::-webkit-scrollbar {
        width: 0.35rem;
    }

    .tag-scroll-window::-webkit-scrollbar-track {
        background: transparent;
    }

    .tag-scroll-window::-webkit-scrollbar-thumb {
        background: color-mix(in oklch, var(--primary) 72%, transparent);
        border-radius: 999px;
    }
</style>

<script>
    class RandomTagList extends HTMLElement {
        connectedCallback() {
            const button = this.querySelector(".tag-random");
            const links = [...this.querySelectorAll(".tag-scroll-window a")];
            if (!(button instanceof HTMLButtonElement) || links.length === 0) return;

            button.addEventListener("click", () => {
                const link = links[Math.floor(Math.random() * links.length)];
                if (link instanceof HTMLAnchorElement) window.location.href = link.href;
            });
        }
    }

    if (!customElements.get("random-tag-list")) {
        customElements.define("random-tag-list", RandomTagList);
    }
</script>
