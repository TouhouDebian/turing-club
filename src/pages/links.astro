---
import { Icon } from "astro-icon/components";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const localSchoolIcon = "/links/tianyi-high-school.png";
const externalSchoolIcon = "/links/tianjin-no4-high-school.png";

const localLinks = [
	{
		titleZh: "本校官网",
		titleEn: "School Website",
		descriptionZh: "江苏省天一中学官方信息发布入口。",
		descriptionEn:
			"The official information portal of Jiangsu Tianyi High School.",
		url: "https://www.tyzx.com.cn/",
		displayUrl: "www.tyzx.com.cn",
		iconSrc: localSchoolIcon,
	},
	{
		titleZh: "学校非官方维基",
		titleEn: "Unofficial School Wiki",
		descriptionZh: "由同学共同维护的非官方知识库。",
		descriptionEn: "An unofficial knowledge base maintained by students.",
		url: "https://tyapwiki.cc.cd/",
		displayUrl: "tyapwiki.cc.cd",
		iconSrc: localSchoolIcon,
	},
];

const externalSchoolLinks = [
	{
		titleZh: "学校介绍",
		titleEn: "School Introduction",
		descriptionZh: "天津市第四中学相关介绍页面。",
		descriptionEn: "An introduction page for Tianjin No.4 High School.",
		url: "https://tj4z.myfxhy.top/",
		displayUrl: "tj4z.myfxhy.top",
		iconSrc: externalSchoolIcon,
	},
	{
		titleZh: "学校Wiki",
		titleEn: "School Wiki",
		descriptionZh: "天津市第四中学相关 Wiki。",
		descriptionEn: "A wiki for Tianjin No.4 High School.",
		url: "https://wiki.myfxhy.top/",
		displayUrl: "wiki.myfxhy.top",
		iconSrc: externalSchoolIcon,
	},
];

const randomFriendUrls = [
	...localLinks.map((link) => link.url),
	...externalSchoolLinks.map((link) => link.url),
];
---

<MainGridLayout title="友链" description="友情链接">
	<div class="space-y-4">
		<section class="card-base link-hero">
			<div>
				<div class="section-label">
					<Icon name="material-symbols:link-rounded" class="text-[1.2rem]" />
					<span class="lang-zh">友链</span>
					<span class="lang-en">Links</span>
				</div>
				<h1>
					<span class="lang-zh">感谢一路相伴</span>
					<span class="lang-en">Thanks for being here</span>
				</h1>
				<p class="lang-zh">
					这里收录与学校、社团资料相关的站点，方便同学快速前往。
				</p>
				<p class="lang-en">
					A small collection of school and club-related sites for quick access.
				</p>
			</div>
			<div class="link-actions">
				<a
					href="https://www.tyzx.com.cn/"
					target="_blank"
					rel="noopener noreferrer"
					class="action-button"
					aria-label="Open school website"
				>
					<img src={localSchoolIcon} alt="" class="action-logo" />
					<span class="lang-zh">本校官网</span>
					<span class="lang-en">School Website</span>
				</a>
				<button
					id="random-friend-link"
					type="button"
					class="action-button"
					aria-label="Open a random link"
				>
					<Icon name="material-symbols:shuffle-rounded" class="text-[1.25rem]" />
					<span class="lang-zh">随机一个友链</span>
					<span class="lang-en">Random Link</span>
				</button>
			</div>
		</section>

		<section class="link-view" data-link-view="root">
			<div class="friend-grid">
				<a class="card-base friend-card category-card" href="/links/local/">
					<div class="friend-icon image-icon">
						<img src={localSchoolIcon} alt="" />
					</div>
					<div class="friend-copy">
						<h2>
							<span class="lang-zh">本校相关</span>
							<span class="lang-en">Tianyi High School</span>
						</h2>
						<p class="lang-zh">本校官网与同学维护的非官方维基。</p>
						<p class="lang-en">Official and student-maintained resources for our school.</p>
						<div class="friend-url">
							<span class="lang-zh">2 个站点</span>
							<span class="lang-en">2 sites</span>
						</div>
					</div>
					<div class="friend-arrow" aria-hidden="true">
						<Icon name="material-symbols:chevron-right-rounded" class="text-[1.7rem]" />
					</div>
				</a>

				<a class="card-base friend-card category-card" href="/links/external/">
					<div class="friend-icon image-icon">
						<img src={externalSchoolIcon} alt="" />
					</div>
					<div class="friend-copy">
						<h2>
							<span class="lang-zh">外校友链</span>
							<span class="lang-en">Other Schools</span>
						</h2>
						<p class="lang-zh">来自其他学校的友链入口。</p>
						<p class="lang-en">Friend links from other schools.</p>
						<div class="friend-url">
							<span class="lang-zh">1 所学校</span>
							<span class="lang-en">1 school</span>
						</div>
					</div>
					<div class="friend-arrow" aria-hidden="true">
						<Icon name="material-symbols:chevron-right-rounded" class="text-[1.7rem]" />
					</div>
				</a>
			</div>
		</section>

	</div>
</MainGridLayout>

<style>
	.link-hero {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.25rem;
		color: rgba(0, 0, 0, 0.9);
		padding: 2rem;
	}

	:global(.dark) .link-hero,
	:global(.dark) .friend-card,
	:global(.dark) .subpage-toolbar {
		color: rgba(255, 255, 255, 0.9);
	}

	.section-label {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		color: var(--primary);
		font-weight: 700;
		margin-bottom: 0.8rem;
	}

	.link-hero h1 {
		font-size: clamp(1.75rem, 4vw, 2.55rem);
		font-weight: 800;
		line-height: 1.15;
		margin: 0;
	}

	.link-hero p {
		color: rgba(0, 0, 0, 0.58);
		font-weight: 600;
		margin: 0.7rem 0 0;
	}

	:global(.dark) .link-hero p,
	:global(.dark) .friend-copy p {
		color: rgba(255, 255, 255, 0.62);
	}

	.link-actions {
		display: grid;
		gap: 0.65rem;
		min-width: 11.5rem;
	}

	.action-button,
	.back-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.45rem;
		border: 0;
		border-radius: 0.75rem;
		background: color-mix(in oklch, var(--primary) 20%, var(--card-bg));
		color: var(--primary);
		cursor: pointer;
		font-weight: 800;
		padding: 0.85rem 1rem;
		text-align: center;
		text-decoration: none;
		white-space: nowrap;
		transition:
			background 0.2s ease,
			transform 0.2s ease;
	}

	.action-button:hover,
	.back-button:hover {
		background: color-mix(in oklch, var(--primary) 28%, var(--card-bg));
		transform: translateY(-1px);
	}

	.action-logo {
		width: 1.45rem;
		aspect-ratio: 1;
		border-radius: 999px;
		object-fit: cover;
	}

	.link-view[hidden] {
		display: none;
	}

	.link-view {
		animation: links-fade-in 0.22s ease both;
	}

	.subpage-toolbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.subpage-toolbar h2 {
		font-size: clamp(1.35rem, 3vw, 2rem);
		font-weight: 800;
		margin: 0;
		text-align: right;
	}

	.friend-grid {
		display: grid;
		gap: 1rem;
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.friend-card {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr) auto;
		align-items: center;
		color: rgba(0, 0, 0, 0.9);
		gap: 1rem;
		padding: 1.25rem;
		text-align: left;
		text-decoration: none;
		transition:
			transform 0.22s ease,
			background 0.22s ease;
		width: 100%;
	}

	button.friend-card {
		border: 0;
		cursor: pointer;
		font: inherit;
	}

	.friend-card:hover {
		background: color-mix(in oklch, var(--card-bg) 88%, var(--primary) 12%);
		transform: translateY(-2px);
	}

	.friend-icon,
	.friend-arrow {
		display: grid;
		place-items: center;
		border-radius: 0.75rem;
		background: color-mix(in oklch, var(--primary) 18%, transparent);
		color: var(--primary);
	}

	.friend-icon {
		width: 4.8rem;
		aspect-ratio: 1;
		overflow: hidden;
	}

	.image-icon img {
		width: 78%;
		aspect-ratio: 1;
		border-radius: 999px;
		object-fit: contain;
	}

	.friend-arrow {
		width: 2.8rem;
		height: 4.8rem;
	}

	.friend-copy h2 {
		font-size: 1.2rem;
		font-weight: 800;
		margin: 0;
	}

	.friend-copy p {
		color: rgba(0, 0, 0, 0.58);
		font-weight: 650;
		line-height: 1.45;
		margin: 0.35rem 0 0;
	}

	.friend-url {
		color: var(--primary);
		font-size: 0.86rem;
		font-weight: 700;
		margin-top: 0.55rem;
	}

	@keyframes links-fade-in {
		from {
			opacity: 0;
			transform: translateY(0.35rem);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 768px) {
		.link-hero,
		.subpage-toolbar {
			align-items: flex-start;
			flex-direction: column;
		}

		.link-hero {
			padding: 1.4rem;
		}

		.link-actions,
		.back-button {
			width: 100%;
		}

		.subpage-toolbar h2 {
			text-align: left;
		}

		.friend-grid {
			grid-template-columns: 1fr;
		}

		.friend-card {
			grid-template-columns: auto minmax(0, 1fr);
		}

		.friend-arrow {
			display: none;
		}
	}
</style>

<script is:inline define:vars={{ randomFriendUrls }}>
	const randomFriendButton = document.getElementById("random-friend-link");
	randomFriendButton?.addEventListener("click", () => {
		if (!Array.isArray(randomFriendUrls) || randomFriendUrls.length === 0) return;
		const index = Math.floor(Math.random() * randomFriendUrls.length);
		window.open(randomFriendUrls[index], "_blank", "noopener,noreferrer");
	});
</script>
